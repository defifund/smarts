<div class="max-w-5xl mx-auto py-8 px-4">
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-2">
      <h1 class="text-3xl font-bold"><%= @contract.name.presence || "Unknown Contract" %></h1>
      <span class="badge badge-primary"><%= @chain.name %></span>
    </div>
    <p class="font-mono text-sm opacity-70"><%= @contract.address %></p>
    <% if @contract.compiler_version.present? %>
      <p class="text-sm opacity-50 mt-1">Solidity <%= @contract.compiler_version %></p>
    <% end %>
  </div>

  <% if @protocol_adapter %>
    <%= render @protocol_adapter.template_partial, adapter: @protocol_adapter %>
  <% end %>

  <div role="tablist" class="tabs tabs-lift tabs-lg">
    <input type="radio" name="contract_view" role="tab" class="tab" aria-label="Docs" checked />
    <div role="tabpanel" class="tab-content bg-base-100 border-base-300 p-6">
      <%= render "contracts/docs" %>
    </div>

    <input type="radio" name="contract_view" role="tab" class="tab" aria-label="Source" />
    <div role="tabpanel" class="tab-content bg-base-100 border-base-300 p-6">
      <%= render "contracts/source" %>
    </div>
  </div>
</div>
