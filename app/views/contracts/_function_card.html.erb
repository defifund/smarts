<% doc = local_assigns[:natspec] || {} %>
<% source = doc["source"] || {} %>

<div class="collapse collapse-arrow bg-base-200">
  <input type="checkbox">
  <div class="collapse-title">
    <div class="font-mono font-medium flex items-center gap-2 flex-wrap">
      <span><%= function_signature_with_params(func) %></span>
      <span class="badge badge-sm <%= kind == 'view' ? 'badge-info' : 'badge-warning' %>"><%= func["stateMutability"] %></span>
      <% if local_assigns[:live_result] %>
        <%= render_live_result(local_assigns[:live_result], func) %>
      <% end %>
    </div>
    <% if doc["notice"].present? %>
      <p class="text-sm mt-2 opacity-80">
        <%= doc["notice"] %><%= ai_badge(source["notice"]) %>
      </p>
    <% end %>
  </div>
  <div class="collapse-content">
    <% if doc["dev"].present? %>
      <div class="alert alert-info alert-soft text-xs mb-3">
        <span class="font-semibold">dev:</span> <%= doc["dev"] %><%= ai_badge(source["dev"]) %>
      </div>
    <% end %>

    <% if func["inputs"]&.any? %>
      <h4 class="font-semibold text-sm mt-2 mb-1">Parameters</h4>
      <table class="table table-sm">
        <thead>
          <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <% func["inputs"].each do |input| %>
            <% param_source = source.dig("params", input["name"]) %>
            <tr>
              <td class="font-mono"><%= input["name"].presence || content_tag(:span, "—", class: "opacity-40") %></td>
              <td class="font-mono text-sm"><%= input["type"] %></td>
              <td class="text-sm opacity-80">
                <%= doc.dig("params", input["name"]) %><%= ai_badge(param_source) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>

    <% if func["outputs"]&.any? %>
      <h4 class="font-semibold text-sm mt-3 mb-1">Returns</h4>
      <table class="table table-sm">
        <thead>
          <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <% func["outputs"].each_with_index do |output, i| %>
            <% return_source = Array(source["returns"])[i] %>
            <tr>
              <td class="font-mono"><%= output["name"].presence || content_tag(:span, "—", class: "opacity-40") %></td>
              <td class="font-mono text-sm"><%= output["type"] %></td>
              <td class="text-sm opacity-80">
                <%= Array(doc["returns"])[i] %><%= ai_badge(return_source) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>
