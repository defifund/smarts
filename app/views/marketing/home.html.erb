<div class="flex flex-col items-center w-full min-h-screen bg-gray-950 text-gray-100 fixed inset-0 z-50 overflow-auto">
  <div class="flex flex-col items-center text-center px-6 pt-20 pb-10 w-full">
    <h1 class="text-6xl md:text-7xl font-extrabold text-white tracking-tight mb-5">smarts.md</h1>
    <p class="text-xl md:text-2xl text-gray-300 mb-3">Live docs for every smart contract.</p>
    <p class="text-sm md:text-base text-gray-500 max-w-lg mx-auto mb-10">
      Enter a verified contract address to generate live documentation with real-time on-chain state.
    </p>

    <%= form_with url: "/", method: :get, local: true, class: "w-full max-w-xl" do %>
      <div class="flex gap-3">
        <input
          type="text"
          name="q"
          placeholder="eth/0x1f98..."
          class="flex-1 px-5 py-4 rounded-xl bg-gray-800/60 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-base"
          required
          pattern="[a-z]+/0x[0-9a-fA-F]{40}"
          title="Format: chain/0xAddress (e.g. eth/0x1f98...)"
        >
        <button
          type="submit"
          class="px-8 py-4 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-xl text-base transition-colors"
        >
          Go
        </button>
      </div>
    <% end %>
  </div>

  <section class="w-full max-w-6xl px-6 pb-20">
    <div class="text-xs uppercase tracking-widest text-gray-500 mb-6 text-center">
      Or start from a curated blue chip
    </div>

    <% @featured_groups.each do |category, items| %>
      <div class="mb-10">
        <h2 class="text-xs uppercase tracking-wider text-gray-400 mb-3 font-semibold"><%= category %></h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          <% items.each do |item| %>
            <a href="/<%= item[:chain] %>/<%= item[:address] %>"
               class="group block p-4 bg-gray-900/60 border border-gray-800 hover:border-blue-500/60 hover:bg-gray-900 rounded-xl transition-all">
              <div class="flex items-baseline justify-between gap-2 mb-1">
                <span class="text-lg font-bold text-white group-hover:text-blue-400 transition-colors"><%= item[:symbol] %></span>
                <span class="text-[10px] uppercase tracking-wider text-gray-500 font-mono">
                  <%= MarketingController::CHAIN_LABELS[item[:chain]] || item[:chain] %>
                </span>
              </div>
              <div class="text-sm text-gray-300 mb-1"><%= item[:name] %></div>
              <div class="text-xs text-gray-500 leading-snug"><%= item[:blurb] %></div>
            </a>
          <% end %>
        </div>
      </div>
    <% end %>
  </section>

  <footer class="pb-8">
    <p class="text-xs text-gray-600">Built by <a href="https://chain.dev" class="text-gray-500 hover:text-gray-400 underline">chain.dev</a></p>
  </footer>
</div>
