<% data = adapter.panel_data %>

<% if data[:error] %>
  <div class="alert alert-warning mb-6">
    Could not read token state: <%= data[:error] %>
  </div>
<% else %>
  <div class="card bg-gradient-to-br from-primary/10 to-secondary/10 border border-base-300 mb-6">
    <div class="card-body">
      <div class="flex items-start justify-between flex-wrap gap-4">
        <div>
          <div class="text-xs opacity-60 font-mono mb-1"><%= adapter.protocol_name %></div>
          <h2 class="text-3xl font-bold">
            <%= data[:symbol] %>
            <% if data[:name].present? && data[:name] != data[:symbol] %>
              <span class="text-base font-normal opacity-60 ml-2"><%= data[:name] %></span>
            <% end %>
          </h2>
          <% if data[:issuer] %>
            <div class="mt-2">
              <% if data[:issuer][:url] %>
                <a href="<%= data[:issuer][:url] %>" target="_blank" rel="noopener" class="badge badge-outline badge-sm hover:badge-primary">
                  Issued by <%= data[:issuer][:name] %> ↗
                </a>
              <% else %>
                <span class="badge badge-outline badge-sm">Issued by <%= data[:issuer][:name] %></span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="mt-6 flex flex-wrap gap-8">
        <% if data[:total_supply_formatted] %>
          <div>
            <div class="text-xs opacity-60 mb-1">Total supply</div>
            <div class="text-xl font-mono"><%= data[:total_supply_formatted] %></div>
            <% if data[:total_supply_raw] %>
              <div class="text-xs opacity-60 mt-1 font-mono">
                raw: <%= number_with_delimiter(data[:total_supply_raw]) %>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if data[:price_usd] %>
          <div>
            <div class="text-xs opacity-60 mb-1">Price</div>
            <div class="text-xl font-mono">$<%= number_with_delimiter(data[:price_usd].round(6)) %></div>
            <div class="text-xs opacity-60 mt-1">via DefiLlama</div>
          </div>
        <% end %>

        <% if data[:market_cap_usd] %>
          <div>
            <div class="text-xs opacity-60 mb-1">Market cap</div>
            <div class="text-xl font-mono">$<%= number_with_delimiter(data[:market_cap_usd].round(0)) %></div>
          </div>
        <% end %>

        <div>
          <div class="text-xs opacity-60 mb-1">Decimals</div>
          <div class="text-xl font-mono"><%= data[:decimals] %></div>
        </div>
      </div>
    </div>
  </div>
<% end %>
