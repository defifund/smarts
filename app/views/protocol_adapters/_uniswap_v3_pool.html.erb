<% data = adapter.panel_data %>

<% if data[:error] %>
  <div class="alert alert-warning mb-6">
    Could not read pool state: <%= data[:error] %>
  </div>
<% else %>
  <div class="card bg-gradient-to-br from-primary/10 to-secondary/10 border border-base-300 mb-6">
    <div class="card-body">
      <div class="flex items-start justify-between flex-wrap gap-4">
        <div>
          <div class="text-xs opacity-60 font-mono mb-1"><%= adapter.protocol_name %></div>
          <h2 class="text-3xl font-bold">
            <%= data[:token0][:symbol] %> / <%= data[:token1][:symbol] %>
            <span class="badge badge-outline ml-2"><%= data[:fee_pct] %></span>
          </h2>
        </div>
      </div>

      <% if data[:price_0_per_1] %>
        <div class="mt-6 flex flex-wrap gap-8">
          <div>
            <div class="text-xs opacity-60 mb-1">Price</div>
            <div class="text-xl font-mono">
              1 <%= data[:token1][:symbol] %> ≈ <%= number_with_delimiter(data[:price_0_per_1].round(6)) %> <%= data[:token0][:symbol] %>
            </div>
            <div class="text-xs opacity-60 mt-1 font-mono">
              1 <%= data[:token0][:symbol] %> = <%= data[:price_1_per_0] %> <%= data[:token1][:symbol] %>
            </div>
          </div>

          <div>
            <div class="text-xs opacity-60 mb-1">Current tick</div>
            <div class="text-xl font-mono"><%= number_with_delimiter(data[:tick]) %></div>
          </div>

          <div>
            <div class="text-xs opacity-60 mb-1">Active liquidity</div>
            <div class="text-xl font-mono"><%= number_with_delimiter(data[:liquidity]) %></div>
          </div>

          <% if data[:tvl_usd] %>
            <div>
              <div class="text-xs opacity-60 mb-1">TVL</div>
              <div class="text-xl font-mono">$<%= number_with_delimiter(data[:tvl_usd].round(0)) %></div>
              <div class="text-xs opacity-60 mt-1">via DefiLlama prices</div>
            </div>
          <% end %>
        </div>
      <% end %>

      <div class="divider my-4"></div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
        <div>
          <div class="opacity-60 text-xs mb-1">token0</div>
          <div class="font-mono"><%= data[:token0][:symbol] %> · <%= data[:token0][:decimals] %> decimals</div>
          <div class="font-mono text-xs opacity-70 break-all"><%= data[:token0][:address] %></div>
        </div>
        <div>
          <div class="opacity-60 text-xs mb-1">token1</div>
          <div class="font-mono"><%= data[:token1][:symbol] %> · <%= data[:token1][:decimals] %> decimals</div>
          <div class="font-mono text-xs opacity-70 break-all"><%= data[:token1][:address] %></div>
        </div>
      </div>
    </div>
  </div>
<% end %>
